# ── Frontend production environment (Vite) ──────────────────────────
# Copy to `.env.production` for local production builds, OR set these
# as Netlify environment variables in the site dashboard.
#
# Must point at the deployed Railway backend, including the /api/v1 suffix.
# Variable MUST be prefixed with VITE_ to be exposed to the client bundle.

VITE_API_BASE_URL=https://your-backend.up.railway.app/api/v1
