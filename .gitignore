# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Frontend build/deps (patterns are path-agnostic — cover frontend/*)
node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Environment
.env
.env.local
.env.*.local
.env.production

# Secrets / tokens (never commit)
*token*.txt
gh_token.txt

# Python (backend)
__pycache__/
*.pyc
venv/
.venv/

# Local databases & artifacts (backend is MySQL-only; these are leftovers)
*.db
*.backup-*.db
*_dump.sql
