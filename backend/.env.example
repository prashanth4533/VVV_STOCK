# Flask
FLASK_ENV=development
SECRET_KEY=change-this-to-a-random-secret-key

# Database
# Preferred single connection string:
# DATABASE_URL=mysql+pymysql://root:your_mysql_password@localhost:3306/vvv_stock?charset=utf8mb4
#
# Or component-based MySQL settings:
DB_HOST=localhost
DB_PORT=3306
DB_NAME=vvv_stock
DB_USER=root
DB_PASSWORD=your_mysql_password

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:4173
